{
  "compilerOptions": {
    // Target modern browsers — no need to support IE
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",

    // Strict mode catches the most bugs at compile time
    "strict": true,
    "noImplicitAny": false,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "skipLibCheck": true,

    // React JSX support
    "jsx": "react-jsx",

    // Path aliases — lets us write @engine/types instead of ../../engine/types
    "baseUrl": ".",
    "paths": {
      "@engine/*": ["src/engine/*"],
      "@store/*": ["src/store/*"],
      "@components/*": ["src/components/*"],
      "@hooks/*": ["src/hooks/*"],
      "@utils/*": ["src/utils/*"]
    },

    // Required for Vite
    "isolatedModules": true,
    "noEmit": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true
  },
  "include": ["src", "tests"],
  "exclude": ["node_modules", "dist"]
}
